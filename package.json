    "@qavajs/memory": "^1.10.3",
    "@qavajs/steps-memory": "^2.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/ws": "^8.18.1",
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
