    "integration-testing",
    "acceptance-testing",
    "functional-testing",
    "browser-testing",
    "mobile-testing",
    "cross-browser",
    "bdd",
    "gherkin",
    "assertions",
    "continuous-delivery",
    "automation-framework"
  ],
