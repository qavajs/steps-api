{
  "name": "@qavajs/steps-api",
  "version": "1.3.0",
  "description": "api steps for @qavajs project",
  "main": "./index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint:write": "npm run pretty && eslint ./ --fix",
    "pretty": "prettier --write ./",
    "test:e2e": "qavajs run --config test-e2e/api.ts",
    "debug:e2e": "qavajs run --config test-e2e/api.ts --tags @debug"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qavajs/steps-api.git"
  },
  "keywords": [
    "QA",
    "Test Automation"
  ],
  "authors": [
    "Alexandr Galichenko",
    "Kiryl Bahdanets",
    "Dzmitry Prakapuk",
    "Alexandr Legchilov"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/qavajs/steps-api/issues"
  },
  "homepage": "https://github.com/qavajs/steps-api#readme",
  "devDependencies": {
    "@cucumber/cucumber": "^12.5.0",
    "@qavajs/cli": "^1.0.1",
    "@qavajs/console-formatter": "^1.1.1",
    "@qavajs/html-formatter": "^1.0.0",
    "@qavajs/memory": "^1.10.3",
    "@qavajs/steps-memory": "^1.0.0",
    "@qavajs/validation": "^1.6.1",
    "@types/chai": "^4.3.20",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/ws": "^8.18.1",
    "body-parser": "^1.20.4",
    "express": "^4.22.1",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "ws": "^8.19.0"
  }
}
